# Omega Training — clean URLs + sensible defaults (Apache / LiteSpeed on 20i)

# Stop Apache guessing extensions on its own
Options -MultiViews
RewriteEngine On

# Serve custom pages for errors (falls back gracefully if missing)
ErrorDocument 404 /index.html

# 1) Send /index and /index.html to the site root
RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
RewriteRule ^ / [R=301,L]

# 2) Redirect any ".html" request to its clean URL (keeps one canonical address)
RewriteCond %{THE_REQUEST} \s/+([^?\s]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 3) Internally serve the matching .html file for an extensionless URL
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
